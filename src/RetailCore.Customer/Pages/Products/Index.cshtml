@page
@model RetailCore.Customer.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<section class="py-5">
    <div class="container-lg">
        <!-- Header -->
        <div class="mb-5">
            <h1 class="display-5 fw-bold mb-2">Our Products</h1>
            <p class="text-muted">Discover premium tech accessories for every need.</p>
        </div>

        <div class="row g-5">
            <!-- Sidebar Filters -->
            <div class="col-lg-3">
                <div class="card position-sticky sticky-card" style="top: 20px">
                    <div class="card-body">
                        <!-- Categories Filter -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Categories</h5>
                            <div class="list-group list-group-flush">
                                <a asp-page="/Products/Index" class="list-group-item list-group-item-action @(string.IsNullOrEmpty(Model.SelectedCategory) ? "active" : "")">
                                    All Products
                                </a>
                                @foreach (var category in Model.Categories)
                                {
                                    <a asp-page="/Products/Index" asp-route-category="@category.Slug" class="list-group-item list-group-item-action @(Model.SelectedCategory == category.Slug ? "active" : "")">
                                        @category.Name
                                    </a>
                                }
                            </div>
                        </div>

                        <hr />

                        <!-- Sort Options -->
                        <div>
                            <h5 class="fw-bold mb-3">Sort By</h5>
                            <div class="list-group list-group-flush">
                                <a asp-page="/Products/Index" asp-route-sortBy="popularity" class="list-group-item list-group-item-action @(Model.SortBy == "popularity" ? "active" : "")">
                                    Most Popular
                                </a>
                                <a asp-page="/Products/Index" asp-route-sortBy="price_low" class="list-group-item list-group-item-action @(Model.SortBy == "price_low" ? "active" : "")">
                                    Price: Low to High
                                </a>
                                <a asp-page="/Products/Index" asp-route-sortBy="price_high" class="list-group-item list-group-item-action @(Model.SortBy == "price_high" ? "active" : "")">
                                    Price: High to Low
                                </a>
                                <a asp-page="/Products/Index" asp-route-sortBy="rating" class="list-group-item list-group-item-action @(Model.SortBy == "rating" ? "active" : "")">
                                    Highest Rated
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Products Grid -->
            <div class="col-lg-9">
                @if (Model.Products.Any())
                {
                    <div class="row g-4">
                        @foreach (var product in Model.Products)
                        {
                            <div class="col-md-6 col-lg-4">
                                @{
                                    ViewData["Product"] = product;
                                }
                                <partial name="Shared/ProductCard" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-inbox display-6 text-muted mb-3"></i>
                        <p class="text-muted fs-5">No products found.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
