@page "{slug}"
@model RetailCore.Customer.Pages.Products.DetailsModel
@{
    ViewData["Title"] = Model.Product?.Name;
    var product = Model.Product;
}

@if (product == null)
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">Product not found.</p>
    </div>
    return;
}

<section class="py-5">
    <div class="container-lg">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-page="/Products/Index">Products</a></li>
                <li class="breadcrumb-item active">@product.Name</li>
            </ol>
        </nav>

        <!-- Product details -->
        <div class="row g-5 mb-5">
            <!-- Image Gallery -->
            <div class="col-lg-5">
                @{
                    var images = product.Images.Any() ? product.Images : new List<string> { "/images/placeholder.png" };
                    var placeholderUrl = @Url.Content("~/assets/images/placeholder.svg");
                }
                <div class="mb-3"
                     style="background-color: #f3f4f6; border-radius: 0.5rem; height: 28rem; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                    <img id="main-product-image" src="@images.First()" alt="@product.Name"
                         style="width: 100%; height: 100%; object-fit: cover;"
                         onerror="this.onerror=null; this.src='@placeholderUrl';" />
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var img in images)
                    {
                        <img src="@img" alt="Thumbnail" class="img-thumbnail"
                             style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;"
                             onclick="document.getElementById('main-product-image').src='@img';"
                             onerror="this.onerror=null; this.src='@placeholderUrl';" />
                    }
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-7">
                <small class="text-muted text-uppercase">@product.Brand.Name</small>
                <h1 class="display-5 fw-bold mb-3">@product.Name</h1>

                <!-- Rating -->
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="d-flex gap-1">
                        @for (int i = 0; i < 5; i++)
                        {
                            if (i < Math.Floor(product.AverageRating))
                            {
                                <i class="fas fa-star star"></i>
                            }
                            else if (i < product.AverageRating)
                            {
                                <i class="fas fa-star-half-alt star"></i>
                            }
                            else
                            {
                                <i class="far fa-star" style="color: #d1d5db;"></i>
                            }
                        }
                    </div>
                    <small class="text-muted">
                        @product.AverageRating.ToString("F1") (@product.ReviewCount reviews)
                    </small>
                </div>

                <!-- Price -->
                <div class="mb-4">
                    <div class="d-flex align-items-center gap-2">
                        @{
                            var price = product.Variants.FirstOrDefault()?.Price ?? 0;
                            var compareAtPrice = product.Variants.FirstOrDefault()?.CompareAtPrice ?? -1;
                            var discount = ((compareAtPrice - price) / compareAtPrice) * 100;
                        }
                        <span class="fs-3 fw-bold">@price.ToString("C")</span>
                        @if (compareAtPrice > price)
                        {
                            <span class="text-muted text-decoration-line-through">@compareAtPrice.ToString("C")</span>
                            <span class="badge bg-danger">Save @Math.Round(discount) %</span>
                        }
                    </div>
                </div>

                <!-- Description -->
                <p class="text-muted mb-4">@product.Description</p>

                <!-- Stock Status -->
                <div class="mb-4 pb-4 border-bottom">
                    @if (product.Status == "Active")
                    {
                        <span class="d-inline-flex align-items-center gap-2 text-success fw-semibold">
                            <i class="fas fa-check-circle"></i> In Stock
                        </span>
                    }
                    else
                    {
                        <span class="d-inline-flex align-items-center gap-2 text-danger fw-semibold">
                            <i class="fas fa-times-circle"></i> Out of Stock
                        </span>
                    }
                </div>

                <!-- Variants & Attributes -->
                @if (product.Variants.Any())
                {
                    <div class="mb-4 pb-4 border-bottom">
                        <h5 class="fw-bold mb-3">Available Options</h5>
                        <div class="d-flex flex-column gap-3">
                            @foreach (var variant in product.Variants)
                            {
                                <div class="d-flex align-items-center gap-3 p-3 border rounded">
                                    <div class="d-flex flex-column gap-1">
                                        <span class="fw-semibold">@variant.Sku</span>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var attr in variant.Attributes)
                                            {
                                                <span class="badge bg-primary">@attr.Key: @attr.Value</span>
                                            }
                                        </div>
                                    </div>
                                    <span class="ms-auto fw-bold">@variant.Price.ToString("C")</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Quantity -->
                <div class="mb-4 pb-4 border-bottom">
                    <h5 class="fw-bold mb-3">Quantity</h5>
                    <div class="d-flex align-items-center gap-2" style="width: fit-content;">
                        <button class="btn btn-light border rounded-corner" style="width: 42px"
                                onclick="decreaseQuantity()">-</button>
                        <input id="quantity-input" type="text" inputmode="numeric" value="1"
                               class="form-control text-center border rounded-corner" style="width: 50px"
                               oninput="handleQuantityInput(this)" onblur="this.value = this.value || '1'" />
                        <button class=" btn btn-light border rounded-corner" style="width: 42px"
                                onclick="increaseQuantity()">+</button>
                    </div>
                </div>

                <!-- Add to Cart Button -->
                <div class="d-flex gap-3 mb-4">
                    <button class="btn btn-primary-gradient flex-grow-1 py-3 fw-bold" style="font-size: 1rem;">
                        <i class="fas fa-shopping-cart me-2"></i> Add to Cart
                    </button>
                    <button class="btn btn-outline-secondary py-3 px-4 fw-bold">
                        <i class="fas fa-heart"></i>
                    </button>
                </div>

                <!-- Additional Info -->
                <div class="d-flex flex-column gap-2 small text-muted">
                    <p class="mb-0">
                        <i class="fas fa-truck me-2" style="color: var(--primary-color);"></i>
                        Free shipping on orders over $50
                    </p>
                    <p class="mb-0">
                        <i class="fas fa-undo me-2" style="color: var(--primary-color);"></i>
                        30-day money-back guarantee
                    </p>
                    <p class="mb-0">
                        <i class="fas fa-phone me-2" style="color: var(--primary-color);"></i>
                        Expert support available 24/7
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function increaseQuantity() {
        const input = document.getElementById('quantity-input');
        input.value = parseInt(input.value || '1') + 1;
    }

    function decreaseQuantity() {
        const input = document.getElementById('quantity-input');
        const currentValue = parseInt(input.value || '1');
        if (currentValue > 1) {
            input.value = currentValue - 1;
        }
    }

    function handleQuantityInput(input) {
        const text = input.value.replace(/\D/g, '');
        if (text === '') {
            input.value = '';
            return;
        }

        const value = parseInt(text);
        if (isNaN(value) || value < 1) {
            input.value = '1';
        } else {
            input.value = value;
        }
    }
</script>
